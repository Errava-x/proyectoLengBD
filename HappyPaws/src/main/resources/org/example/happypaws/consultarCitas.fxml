         <TextField fx:id="buscador" layoutX="215.0" layoutY="79.0" prefHeight="26.0" prefWidth="761.0" scaleY="1.5" style="-fx-background-color: WHITE; -fx-background-radius: 30;" />
         <Button fx:id="buscarPorID" layoutX="329.0" layoutY="125.0" mnemonicParsing="false" onAction="#cargarTablaPorId" scaleX="1.4" scaleY="1.4" style="-fx-background-radius: 10; -fx-background-color: #5568E3;" text="ID" textFill="WHITE">
