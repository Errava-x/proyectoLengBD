         <Button fx:id="buscarPorMascota" layoutX="502.0" layoutY="124.0" mnemonicParsing="false" onAction="#cargarTablaPorMascota" scaleX="1.4" scaleY="1.4" style="-fx-background-radius: 10; -fx-background-color: #5568E3;" text="Mascota" textFill="WHITE" />
         <Button fx:id="cargarTodo" layoutX="604.0" layoutY="118.0" mnemonicParsing="false" onAction="#cargarTabla" prefHeight="40.0" prefWidth="109.0" style="-fx-background-radius: 10; -fx-background-color: #5568E3;" text="Ver todo" textFill="WHITE">
